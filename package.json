{
  "name": "reading-vimrc-list",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "fmt": "npm-run-all2 --parallel",
    "fmt:package": "sort-package-json",
    "fmt:biome": "biome check --write --unsafe",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "npm-run-all2": "^8.0.4",
    "sort-package-json": "^3.6.1",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
